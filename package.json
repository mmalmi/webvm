{
	"name": "iris-webvm",
	"version": "2.0.0",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"lint": "node scripts/check-source-quality.mjs",
		"build": "node scripts/assert-v86-guest-assets.mjs && vite build",
		"guest:build": "bash scripts/build-v86-guest.sh && npm run state:build",
		"state:build": "node scripts/build-v86-state.mjs",
		"preview": "vite preview --host 127.0.0.1",
		"test:e2e": "npm run build && playwright test",
		"test:production": "playwright test --config playwright.production.config.js",
		"deploy:webvm": "node scripts/deploy-webvm.mjs",
		"deploy:webvm:dry-run": "node scripts/deploy-webvm.mjs --dry-run"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-static": "^3.0.5",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"@xterm/addon-fit": "^0.10.0",
		"@xterm/xterm": "^5.5.0",
		"autoprefixer": "^10.4.20",
		"postcss": "^8.4.47",
		"svelte": "^4.2.7",
		"tailwindcss": "^3.4.9",
		"vite": "^5.0.3",
		"vite-plugin-static-copy": "^1.0.6",
		"zxing-wasm": "^3.1.0"
	},
	"type": "module",
	"dependencies": {
		"@fips/core": "file:vendor/fips/fips-core-0.0.15.tgz",
		"@fips/transport-ethernet": "file:vendor/fips/fips-transport-ethernet-0.0.14.tgz",
		"@fips/transport-webrtc": "file:vendor/fips/fips-transport-webrtc-0.0.22.tgz",
		"nostr-pubsub": "file:vendor/nostr-pubsub-0.1.2.tgz",
		"nostr-tools": "^2.23.9",
		"v86": "^0.5.424"
	}
}
