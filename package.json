{
	"name": "iris-webvm",
	"version": "2.0.0",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"check": "svelte-check",
		"verify:dependencies": "node scripts/verify-vendored-dependencies.mjs",
		"lint": "npm run verify:dependencies && node scripts/check-source-quality.mjs",
		"build": "node scripts/assert-v86-guest-assets.mjs && vite build && node scripts/assert-webvm-build.mjs",
		"guest:build": "bash scripts/build-v86-guest.sh && npm run state:build",
		"state:build": "node scripts/build-v86-state.mjs",
		"preview": "vite preview --host 127.0.0.1",
		"perf:startup": "node scripts/measure-v86-startup.mjs",
		"test:unit": "node --test tests/release/*.spec.mjs",
		"test:e2e": "npm run build && env -u NO_COLOR playwright test",
		"test:release": "npm run test:unit && npm run lint && npm run check && npm run verify:dependencies:remote && npm run build && env -u NO_COLOR NVPN_WEBVM_REAL_E2E=1 playwright test tests/e2e/v86-route.spec.js tests/e2e/v86-persistence-real.spec.js tests/e2e/v86-entropy-real.spec.js tests/e2e/webvm-fips-identity.spec.js tests/e2e/webvm-nostr-pubsub-service.spec.js tests/e2e/webvm-nostr-pubsub-version.spec.js && env -u NO_COLOR NVPN_WEBVM_REAL_E2E=1 playwright test tests/e2e/webvm-native-nostr-vpn.spec.js",
		"test:production": "env -u NO_COLOR playwright test --config playwright.production.config.js",
		"deploy:webvm": "node scripts/deploy-webvm.mjs",
		"deploy:webvm:dry-run": "node scripts/deploy-webvm.mjs --dry-run",
		"verify:dependencies:remote": "VERIFY_VENDORED_REMOTE=1 node scripts/verify-vendored-dependencies.mjs"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.69.3",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@types/node": "^24.13.3",
		"@xterm/addon-fit": "^0.10.0",
		"@xterm/xterm": "^5.5.0",
		"autoprefixer": "^10.5.3",
		"postcss": "^8.5.19",
		"svelte": "^5.56.5",
		"svelte-check": "^4.7.3",
		"tailwindcss": "^3.4.9",
		"typescript": "~5.9.3",
		"vite": "^8.1.5",
		"vite-plugin-static-copy": "^4.1.1",
		"zxing-wasm": "^3.1.0"
	},
	"type": "module",
	"dependencies": {
		"@fips/core": "file:vendor/fips/fips-core-0.0.25.tgz",
		"@fips/transport-ethernet": "file:vendor/fips/fips-transport-ethernet-0.0.24.tgz",
		"@fips/transport-webrtc": "file:vendor/fips/fips-transport-webrtc-0.0.41.tgz",
		"nostr-pubsub": "file:vendor/nostr-pubsub-0.3.0.tgz",
		"nostr-tools": "^2.23.9",
		"v86": "^0.5.424"
	},
	"overrides": {
		"cookie@0.6.0": "1.0.2",
		"picomatch@2.3.1": "2.3.2"
	}
}
